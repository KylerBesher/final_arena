{
    "name": "next-netlify-platform-starter",
    "version": "0.1.0",
    "private": true,
    "scripts": {
        "dev": "npm run watch:cms & next dev",
        "build": "npm run build:cms && next build",
        "start": "next start",
        "lint": "next lint",
        "build:cms": "esbuild src/admin/index.js --bundle --outfile=public/admin/cms.js --platform=node --format=iife --global-name=CMS --loader:.js=jsx --loader:.jsx=jsx --define:process.env.NODE_ENV=\\\"production\\\" --define:global=window --external:server-only --alias:bright=./src/admin/shims/bright.js",
        "dev:cms": "esbuild src/admin/index.js --bundle --outfile=public/admin/cms.js --platform=node --format=iife --global-name=CMS --loader:.js=jsx --loader:.jsx=jsx --define:process.env.NODE_ENV=\\\"development\\\" --define:global=window --define:process.env.REACT_APP_SUPPRESS_WARNINGS=\\\"true\\\" --external:server-only --alias:bright=./src/admin/shims/bright.js",
        "watch:cms": "nodemon --watch src/admin --ext js,jsx --exec 'npm run dev:cms'",
        "format": "prettier --write \"**/*.{js,jsx,ts,tsx,json,md}\"",
        "lint:fix": "next lint --fix",
        "fix": "npm run format && npm run lint:fix"
    },
    "dependencies": {
        "@apollo/client": "^3.12.4",
        "@emotion/react": "^11.14.0",
        "@emotion/styled": "^11.14.0",
        "@heroicons/react": "^2.2.0",
        "@netlify/blobs": "^8.1.0",
        "@portabletext/react": "^3.2.0",
        "@shopify/shopify-api": "^11.6.1",
        "apollo-server-micro": "^3.13.0",
        "blobshape": "^1.0.0",
        "bright": "^0.8.5",
        "decap-cms-app": "^3.5.0",
        "graphql": "^16.10.0",
        "graphql-request": "^7.1.2",
        "gray-matter": "^4.0.3",
        "js-yaml": "^4.1.0",
        "markdown-to-jsx": "^7.4.5",
        "next": "15.1.3",
        "react": "18.3.1",
        "react-dom": "18.3.1",
        "slate-hyperscript": "^0.100.0",
        "unique-names-generator": "^4.7.1"
    },
    "devDependencies": {
        "@babel/core": "^7.26.7",
        "@babel/preset-react": "^7.26.3",
        "@tailwindcss/typography": "^0.5.16",
        "autoprefixer": "^10.4.18",
        "babel-loader": "^9.2.1",
        "chokidar": "^3.6.0",
        "daisyui": "^4.12.8",
        "esbuild": "^0.24.2",
        "eslint": "^8.57.1",
        "eslint-config-next": "^15.1.3",
        "eslint-config-prettier": "^9.1.0",
        "frontmatter-markdown-loader": "^3.7.0",
        "nodemon": "^3.1.9",
        "path-browserify": "^1.0.1",
        "postcss": "^8.4.36",
        "prettier": "^3.4.2",
        "stream-browserify": "^3.0.0",
        "tailwindcss": "^3.4.17",
        "util": "^0.12.5",
        "webpack": "^5.97.1",
        "webpack-cli": "^6.0.1"
    }
}
